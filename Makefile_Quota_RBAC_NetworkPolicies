SHELL := /bin/bash


# Default target
.DEFAULT_GOAL := help
# ------------------------------ GLOBAL CONFIG --------------------------------------
RED    											:= \033[1;31m
YELLOW 											:= \033[1;33m
GREEN  											:="\033[1;32m"
CYAN   											:= \033[1;36m
RESET  											:= \033[0m

NAMESPACE_TEAM_ALPHA      						:= team-alpha
NAMESPACE_TEAM_BETA		  						:= team-beta
POD_SECURITY_ADMISSION_ENFORCEMENT_LEVEL    	:= restricted
LABEL_TEAM_1									:= alpha
LABEL_TEAM_2									:= beta

RESOURCE_QUOTA_TEAM_ALPHA_FILE					:= quotas/team-alpha-quota.yaml
RBAC_TEAM_ALPHA_ROLE_FILE						:= rbac/team-alpha-developer-role.yaml
RBAC_TEAM_ALPHA_VIEWER_ROLE_FILE				:= rbac/team-alpha-viewer-role.yaml
RBAC_TEAM_ALPHA_DEVELOPER_ROLEBINDING_FILE		:= rbac/team-alpha-developer-binding.yaml
RBAC_PLATFORM_OBSERVABILITY_CLUSTERROLE_FILE    := rbac/platform-observability-clusterrole.yaml
RBAC_TEAM_ALPHA_PLATFORM_EXTENDED_VIEW_FILE     := rbac/team-alpha-platform-extended-view.yaml


# Self-documenting help: list targets with "##" comments
.PHONY: help #- Show targets
help: ## Show all available targets with short descriptions.
	# This target reads the Makefile and prints any line ending with ##.
	# Use this when you want to discover available commands quickly.
	# Expected output: a list of targets and one-line descriptions.
	@awk 'BEGIN {FS = ":.*##"; printf "\nUsage:\n  make <target>\n\nTargets:\n"} /^[a-zA-Z0-9_.-]+:.*##/ { printf "  %-28s %s\n", $$1, $$2 }' $(MAKEFILE_LIST)

# Convenience wrapper to call setup Makefile targets
.PHONY: setup-minikube
setup-minikube: ## Ensure Minikube cluster is running with correct profile
	@echo -e "$(CYAN) Ensure Minikube cluster is running with correct profile $(RESET)"; \
	$(MAKE) -f Makefile_Setup ensure-minikube
	$(MAKE) -f Makefile_Setup enable-minikube-addons
	$(MAKE) -f Makefile_Setup check-clusterinfo
	$(MAKE) -f Makefile_Setup kubectl-get-nodes

.PHONY: create-namespaces-for-team-alpha-and-team-beta
create-namespaces-for-team-alpha-and-team-beta: ## Create or update namespaces for team-alpha and team-beta
	@printf '$(CYAN)%s$(RESET)\n' "Apply namespace $(NAMESPACE_TEAM_ALPHA)"
	@kubectl create namespace $(NAMESPACE_TEAM_ALPHA) --dry-run=client -o yaml | kubectl apply -f -
	@printf '$(CYAN)%s$(RESET)\n' "Apply namespace $(NAMESPACE_TEAM_BETA)"
	@kubectl create namespace $(NAMESPACE_TEAM_BETA) --dry-run=client -o yaml | kubectl apply -f -

.PHONY: assign-labels-and-pod-security-admission-enforcement-to-namespaces
assign-labels-and-pod-security-admission-enforcement-to-namespaces: ## Assign labels and Pod Security Admission enforcement to namespaces
	@printf '$(CYAN)%s$(RESET)\n' "Label namespace $(NAMESPACE_TEAM_ALPHA)"
	@kubectl label namespace $(NAMESPACE_TEAM_ALPHA) team=$(LABEL_TEAM_1) pod-security.kubernetes.io/enforce=$(POD_SECURITY_ADMISSION_ENFORCEMENT_LEVEL) --overwrite
	@printf '$(CYAN)%s$(RESET)\n' "Label namespace $(NAMESPACE_TEAM_BETA)"
	@kubectl label namespace $(NAMESPACE_TEAM_BETA) team=$(LABEL_TEAM_2) pod-security.kubernetes.io/enforce=$(POD_SECURITY_ADMISSION_ENFORCEMENT_LEVEL) --overwrite

.PHONY: delete-namespaces
delete-namespaces: ## Delete team-alpha and team-beta namespaces
	@printf '$(CYAN)%s$(RESET)\n' "Delete namespace $(NAMESPACE_TEAM_ALPHA)"
	@kubectl delete namespace $(NAMESPACE_TEAM_ALPHA) --ignore-not-found
	@printf '$(CYAN)%s$(RESET)\n' "Delete namespace $(NAMESPACE_TEAM_BETA)"
	@kubectl delete namespace $(NAMESPACE_TEAM_BETA) --ignore-not-found

# A basic per-tenant quota 
.PHONY: apply-quota-to-namespace-team-alpha
apply-quota-to-namespace-team-alpha: ## Apply ResourceQuota for team-alpha namespace
	@test -f $(RESOURCE_QUOTA_TEAM_ALPHA_FILE) || (echo "Missing file: $(RESOURCE_QUOTA_TEAM_ALPHA_FILE)" && exit 1)
	@printf '$(CYAN)%s$(RESET)\n' "Apply ResourceQuota for team-alpha"
	kubectl apply -f $(RESOURCE_QUOTA_TEAM_ALPHA_FILE)

# Namespace-Scoped Roles and RoleBindings
.PHONY: apply-rbac-role-to-namespace-team-alpha
apply-rbac-role-to-namespace-team-alpha: ## Apply developer Role for team-alpha namespace
	@test -f $(RBAC_TEAM_ALPHA_ROLE_FILE) || (echo "Missing file: $(RBAC_TEAM_ALPHA_ROLE_FILE)" && exit 1)
	@printf '$(CYAN)%s$(RESET)\n' "Apply RBAC Role for team-alpha"
	kubectl apply -f $(RBAC_TEAM_ALPHA_ROLE_FILE)

.PHONY: apply-rbac-viewer-role-to-namespace-team-alpha
apply-rbac-viewer-role-to-namespace-team-alpha: ## Apply viewer Role for team-alpha namespace
	@test -f $(RBAC_TEAM_ALPHA_VIEWER_ROLE_FILE) || (echo "Missing file: $(RBAC_TEAM_ALPHA_VIEWER_ROLE_FILE)" && exit 1)
	@printf '$(CYAN)%s$(RESET)\n' "Apply viewer RBAC Role for team-alpha"
	kubectl apply -f $(RBAC_TEAM_ALPHA_VIEWER_ROLE_FILE)

.PHONY: apply-rbac-developer-rolebinding-to-namespace-team-alpha
apply-rbac-developer-rolebinding-to-namespace-team-alpha: ## Apply developer RoleBinding for team-alpha namespace
	@test -f $(RBAC_TEAM_ALPHA_DEVELOPER_ROLEBINDING_FILE) || (echo "Missing file: $(RBAC_TEAM_ALPHA_DEVELOPER_ROLEBINDING_FILE)" && exit 1)
	@printf '$(CYAN)%s$(RESET)\n' "Apply developer RoleBinding for team-alpha"
	kubectl apply -f $(RBAC_TEAM_ALPHA_DEVELOPER_ROLEBINDING_FILE)

# --------------------------------------------------------------------------------
# What to apply
# Your files are:
# 	1. rbac/platform-observability-clusterrole.yaml
# 	The first one defines the permissions to be merged into the built-in 
# 	view role. 
# 	2. rbac/team-alpha-platform-extended-view.yaml
# 	The second one binds that view role to the team-alpha-sre 
# 	group inside the team-alpha namespace.
# --------------------------------------------------------------------------------
.PHONY: apply-own-aggregated-clusterrole-platform-observability-with-lable-aggregate-to-view
apply-rbac-own-aggregated-clusterrole-platform-observability-with-lable-aggregate-to-view: ## Apply aggregated ClusterRole for observability access
	@test -f $(RBAC_PLATFORM_OBSERVABILITY_CLUSTERROLE_FILE) || (echo "Missing file: $(RBAC_PLATFORM_OBSERVABILITY_CLUSTERROLE_FILE)" && exit 1)
	@printf '$(CYAN)%s$(RESET)\n' "Apply platform observability ClusterRole"
	kubectl apply -f $(RBAC_PLATFORM_OBSERVABILITY_CLUSTERROLE_FILE)

.PHONY: apply-rolebinding-to-give-group-team-alpha-sre-access-to-built-in-view-clusterrole-platform-observability-for-namespace-team-alpha
apply-rbac-rolebinding-to-give-group-team-alpha-sre-access-to-built-in-view-clusterrole-platform-observability-for-namespace-team-alpha: ## Apply extended view RoleBinding for team-alpha SRE group
	@test -f $(RBAC_TEAM_ALPHA_PLATFORM_EXTENDED_VIEW_FILE) || (echo "Missing file: $(RBAC_TEAM_ALPHA_PLATFORM_EXTENDED_VIEW_FILE)" && exit 1)
	@printf '$(CYAN)%s$(RESET)\n' \
		"Apply team-alpha extended view RoleBinding " \
		"	 apply-rolebinding-to-give-group-team-alpha-sre" \
		"    access-to-built-in-view-clusterrole-platform-observability" \
		"    for-namespace-team-alpha";
	kubectl apply -f $(RBAC_TEAM_ALPHA_PLATFORM_EXTENDED_VIEW_FILE)

.PHONY: apply-platform-observability-rbac
apply-rbac-platform-observability: ## Apply both observability ClusterRole and team-alpha RoleBinding
	@$(MAKE) apply-platform-observability-clusterrole
	@$(MAKE) apply-team-alpha-platform-extended-view


# Paths
MYAPP_SERVICEACCOUNT_FILE := t07-Kubernetes-RBAC-and-Namespace-Isolation/myapp_1/rbac/myapp-serviceaccount.yaml
MYAPP_DEPLOYMENT_FILE     := t07-Kubernetes-RBAC-and-Namespace-Isolation/myapp_1/rbac/myapp-deployment-snippet.yaml

DEPLOY_BOT_SERVICEACCOUNT_FILE := t07-Kubernetes-RBAC-and-Namespace-Isolation/myapp_1/rbac/deploy-bot-serviceaccount.yaml
DEPLOY_BOT_ROLE_FILE           := t07-Kubernetes-RBAC-and-Namespace-Isolation/myapp_1/rbac/deploy-bot-role.yaml
DEPLOY_BOT_BINDING_FILE        := t07-Kubernetes-RBAC-and-Namespace-Isolation/myapp_1/rbac/deploy-bot-binding.yaml

.PHONY: apply-myapp-serviceaccount
apply-myapp-serviceaccount: ## Apply ServiceAccount for myapp (no token automount)
	@test -f $(MYAPP_SERVICEACCOUNT) || (echo "Missing file: $(MYAPP_SERVICEACCOUNT)" && exit 1)
	@printf '$(CYAN)%s$(RESET)\n' "Apply ServiceAccount for myapp"
	kubectl apply -f $(MYAPP_SERVICEACCOUNT)

.PHONY: apply-myapp-deployment
apply-myapp-deployment: ## Apply myapp Deployment (uses myapp ServiceAccount)
	@test -f $(MYAPP_DEPLOYMENT) || (echo "Missing file: $(MYAPP_DEPLOYMENT)" && exit 1)
	@printf '$(CYAN)%s$(RESET)\n' "Apply myapp Deployment"
	kubectl apply -f $(MYAPP_DEPLOYMENT)

.PHONY: apply-myapp
apply-myapp: ## Apply myapp ServiceAccount and Deployment
	@$(MAKE) apply-myapp-serviceaccount
	@$(MAKE) apply-myapp-deployment

.PHONY: apply-deploy-bot-serviceaccount
apply-deploy-bot-serviceaccount: ## Apply ServiceAccount for deploy-bot
	@test -f $(DEPLOY_BOT_SERVICEACCOUNT) || (echo "Missing file: $(DEPLOY_BOT_SERVICEACCOUNT)" && exit 1)
	@printf '$(CYAN)%s$(RESET)\n' "Apply ServiceAccount for deploy-bot"
	kubectl apply -f $(DEPLOY_BOT_SERVICEACCOUNT)

.PHONY: apply-deploy-bot-role
apply-deploy-bot-role: ## Apply Role for deployment restarter in team-alpha
	@test -f $(DEPLOY_BOT_ROLE) || (echo "Missing file: $(DEPLOY_BOT_ROLE)" && exit 1)
	@printf '$(CYAN)%s$(RESET)\n' "Apply Role deployment-restarter"
	kubectl apply -f $(DEPLOY_BOT_ROLE)

.PHONY: apply-deploy-bot-binding
apply-deploy-bot-binding: ## Bind deploy-bot ServiceAccount to deployment-restarter Role
	@test -f $(DEPLOY_BOT_BINDING) || (echo "Missing file: $(DEPLOY_BOT_BINDING)" && exit 1)
	@printf '$(CYAN)%s$(RESET)\n' "Apply RoleBinding for deploy-bot"
	kubectl apply -f $(DEPLOY_BOT_BINDING)

.PHONY: apply-deploy-bot-rbac
apply-deploy-bot-rbac: ## Apply deploy-bot ServiceAccount, Role, and RoleBinding
	@$(MAKE) apply-deploy-bot-serviceaccount
	@$(MAKE) apply-deploy-bot-role
	@$(MAKE) apply-deploy-bot-binding